#!/usr/bin/env bash

# TODO: Check if `rename -c *.txt` is better suited

set -eufo pipefail

tmpdir="$(mktemp --directory)"

find . -maxdepth 1 -mindepth 1 -print0 \
| while IFS= read -r -d '' i
  do
    name="$(basename "$i")"
    lower="$(printf '%s\n' "$name" | tr '[:upper:]' '[:lower:]')"

    if test "$name" != "$lower"
    then
      mv -- "$i" "$tmpdir/$name"
      mv -- "$tmpdir/$name" "$lower"
    fi
  done

rmdir "$tmpdir"
